{
  "$schema": "https://mintlify.com/docs.json",
  "name": "GurStore",
  "theme": "almond",
  "language": "tr",
  "logo": {
    "light": "/images/light-all-big.png",
    "dark": "/images/dark-all-big.png",
    "href": "https://gurstore.net/"
  },
  "favicon": {
    "light": "/images/light-icon.png",
    "dark": "/images/dark-icon.png"
  },
  "colors": {
    "primary": "#ffae00",
    "light": "#040404",
    "dark": "#ff8500"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Hemen Başla",
      "href": "/quickstart"
    },
    "links": [
      {
        "href": "https://demo.gurstore.net",
        "label": "Demo"
      },
      {
        "href": "https://gurstore.net/contact",
        "label": "İletişim"
      }
    ]
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Dokümantasyon",
        "groups": [
          {
            "group": "Başlarken",
            "pages": [
              "introduction",
              "quickstart",
              "account-setup"
            ]
          },
          {
            "group": "Kurulum",
            "pages": [
              "installation/overview",
              "installation/gurstore-hosting",
              "installation/domain-dns",
              "installation/cpanel",
              "installation/plesk",
              "installation/pterodactyl",
              "installation/ubuntu-vps",
              "installation/setup-wizard",
              "installation/troubleshooting",
              "installation/license"
            ]
          },
          {
            "group": "Mağaza & Ürünler",
            "pages": [
              "products/overview",
              "products/digital-products",
              "products/license-keys",
              "products/serial-keys",
              "products/variants-pricing"
            ]
          },
          {
            "group": "Satış",
            "pages": [
              "selling/checkout",
              "selling/payments",
              "selling/coupons-discounts",
              "selling/orders"
            ]
          },
          {
            "group": "Müşteri Özellikleri",
            "pages": [
              "customers/dashboard",
              "customers/wallet-balance",
              "customers/loyalty-points",
              "customers/affiliate-referrals",
              "customers/support-tickets"
            ]
          },
          {
            "group": "Yapılandırma",
            "pages": [
              "configuration/theme-editor",
              "configuration/payment-setup",
              "configuration/oauth-social-login",
              "configuration/discord-integration",
              "configuration/team-staff",
              "configuration/maintenance-mode",
              "configuration/leaderos-plugin"
            ]
          }
        ]
      },
      {
        "tab": "API Referansı",
        "groups": [
          {
            "group": "Genel Bakış",
            "pages": [
              "api/introduction",
              "api/authentication"
            ]
          },
          {
            "group": "Mağaza (Storefront)",
            "pages": [
              "api/products",
              "api/cart",
              "api/checkout"
            ]
          },
          {
            "group": "Müşteri API",
            "pages": [
              "api/customer-dashboard",
              "api/orders-licenses",
              "api/wallet-tickets"
            ]
          },
          {
            "group": "Özel API v1",
            "pages": [
              "api/v1-overview",
              "api/v1-license-verify",
              "api/v1-order-create"
            ]
          },
          {
            "group": "Webhooks",
            "pages": [
              "api/webhooks"
            ]
          }
        ]
      }
    ]
  },
  "background": {
    "decoration": "grid"
  },
  "contextual": {
    "options": [
      "claude",
      "download-pdf",
      "copy"
    ],
    "display": "toc"
  }
}
